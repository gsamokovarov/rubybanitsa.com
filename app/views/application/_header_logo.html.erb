<%= link_to root_path, class: "flex items-center gap-3 group" do %>
  <%= render "logo_icon", classes: "w-12 h-12 group-hover:animate-spin" %>
  <% vibe = Current.vibe? %>
  <%= image_tag(vibe ? "logo-text-vibe.svg" : "logo-text.svg",
                alt: "#{vibe ? "Vibe Banitsa" : "Ruby Banitsa"} logo text",
                class: "mt-1 h-5 sm:h-6 w-auto") %>
<% end %>
