<% event = EventDetails.new(@event) %>

<div data-controller="pip" class="flex flex-col items-center gap-6">
  <div class="inline-flex p-1 bg-white border-2 border-black rounded-lg shadow-brutal">
    <% [["broadcast", "Max video"], ["framed", "Framed"], ["sidebar", "Sidebar"], ["canvas", "Canvas"]].each do |style, label| %>
      <button
        type="button"
        data-pip-target="tab"
        data-style="<%= style %>"
        data-action="pip#select"
        class="px-5 py-2 rounded-md font-semibold transition"
      >
        <%= label %>
      </button>
    <% end %>
  </div>

  <div id="pip" class="relative w-[1280px] aspect-video overflow-hidden">
    <div data-pip-target="frame" data-style="broadcast" class="absolute inset-0 bg-chroma-green">
      <div class="absolute inset-0 flex items-center justify-center">
        <%= render "play_icon", classes: "w-28 h-28 text-black/25" %>
      </div>

      <div class="absolute top-6 left-6 flex items-center gap-2 bg-white border-2 border-black rounded-md px-4 py-2 shadow-brutal-md">
        <%= render "logo_icon", classes: "w-9 h-9" %>
        <span class="logo-wordmark text-2xl"><%= brand_name event.vibe? %></span>
      </div>

      <div class="absolute bottom-6 left-6 max-w-[55%] bg-white border-2 border-black rounded-md px-5 py-3 shadow-brutal-md">
        <div class="flex items-baseline gap-3 text-2xl">
          <span class="vibe-display font-semibold leading-none"><%= event.title %></span>
          <span class="text-neutral-400">·</span>
          <time datetime="<%= event.time.iso8601 %>" class="font-mono font-medium text-neutral-600 leading-none whitespace-nowrap"><%= event.time.strftime("%-d %B") %></time>
        </div>
      </div>

      <%= render "speaker_slot", classes: "absolute bottom-6 right-6 w-80" %>
    </div>

    <div data-pip-target="frame" data-style="framed" class="absolute inset-0 brand-surface flex flex-col px-16 py-12 hidden">
      <header class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <%= render "logo_icon", classes: "w-14 h-14" %>
          <span class="logo-wordmark text-4xl"><%= brand_name event.vibe? %></span>
        </div>
        <time datetime="<%= event.time.iso8601 %>" class="text-2xl font-mono font-medium text-neutral-700"><%= event.time.strftime("%-d %B") %></time>
      </header>

      <div class="grow min-h-0 flex items-center justify-center gap-6 py-8">
        <div class="basis-2/3 p-3 bg-white border-2 border-black rounded-md shadow-brutal-md">
          <div class="aspect-video border-2 border-black rounded-sm overflow-hidden bg-chroma-green flex items-center justify-center">
            <%= render "play_icon", classes: "w-24 h-24 text-black/25" %>
          </div>
        </div>

        <%= render "speaker_slot", classes: "basis-1/3" %>
      </div>

      <footer class="flex items-center gap-3 text-3xl">
        <span class="vibe-display font-semibold leading-none"><%= event.title %></span>
      </footer>
    </div>

    <div data-pip-target="frame" data-style="sidebar" class="absolute inset-0 flex hidden">
      <aside class="brand-surface w-[36%] shrink-0 flex flex-col gap-8 p-12 border-r-2 border-black">
        <div class="flex items-center gap-3">
          <%= render "logo_icon", classes: "w-12 h-12" %>
          <span class="logo-wordmark text-3xl"><%= brand_name event.vibe? %></span>
        </div>

        <%= render "speaker_slot", classes: "w-full" %>

        <div class="mt-auto space-y-4">
          <h2 class="vibe-display text-4xl font-bold leading-tight"><%= event.title %></h2>
          <div class="flex items-center gap-2 text-xl font-mono text-neutral-700">
            <time datetime="<%= event.time.iso8601 %>"><%= event.time.strftime("%-d %B") %></time>
          </div>
        </div>
      </aside>

      <div class="grow bg-chroma-green flex items-center justify-center">
        <%= render "play_icon", classes: "w-28 h-28 text-black/25" %>
      </div>
    </div>

    <div data-pip-target="frame" data-style="canvas" class="absolute inset-0 brand-surface p-12 flex items-center justify-center hidden">
      <div class="h-full aspect-video p-3 bg-white border-2 border-black rounded-md shadow-brutal-md">
        <div class="w-full h-full border-2 border-black rounded-sm overflow-hidden bg-chroma-green flex items-center justify-center">
          <%= render "play_icon", classes: "w-28 h-28 text-black/25" %>
        </div>
      </div>

      <div class="absolute top-8 left-8 flex items-center gap-2 bg-white border-2 border-black rounded-md px-4 py-2 shadow-brutal-md">
        <%= render "logo_icon", classes: "w-9 h-9" %>
        <span class="logo-wordmark text-2xl"><%= brand_name event.vibe? %></span>
      </div>

      <div class="absolute bottom-8 left-8 bg-white border-2 border-black rounded-md px-5 py-3 shadow-brutal-md">
        <div class="flex items-baseline gap-3 text-2xl">
          <span class="vibe-display font-semibold leading-none"><%= event.title %></span>
          <span class="text-neutral-400">·</span>
          <time datetime="<%= event.time.iso8601 %>" class="font-mono font-medium text-neutral-600 leading-none whitespace-nowrap"><%= event.time.strftime("%-d %B") %></time>
        </div>
      </div>

      <%= render "speaker_slot", classes: "absolute bottom-8 right-8 w-80" %>
    </div>
  </div>
</div>
