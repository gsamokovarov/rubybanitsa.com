<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= yield :title %><%= brand_name %></title>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    <%= yield :head %>

    <%= csrf_meta_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    >

    <style>
      /* BT Mono Bold — the face the logo wordmark is set in (app/assets/fonts) */
      @font-face {
        font-family: "BT Mono";
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url(<%= asset_path "bt_mono-Bold.woff2" %>) format("woff2"),
             url(<%= asset_path "bt_mono-Bold.woff" %>) format("woff");
      }
    </style>

    <% if Current.vibe? %>
      <link
        href="https://fonts.googleapis.com/css2?family=Bangers&display=swap"
        rel="stylesheet"
      >
    <% end %>

    <%= stylesheet_link_tag "app", media: "all", "data-turbolinks-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbolinks-track": "reload" %>
  </head>

  <body class="antialiased bg-brand-50 h-full <%= "vibe" if Current.vibe? %>">
    <div class="flex flex-col h-full">
      <%= render "header" %>

      <div class="grow">
        <%= render "container" do %>
          <div class="lg:flex lg:items-start">
            <main class="grow lg:pr-10 xl:pr-16">
              <%= yield %>
            </main>

            <%= render "sidebar", jobs: @current_jobs %>
          </div>
        <% end %>
      </div>

      <%= render "footer" %>
    </div>
  </body>
</html>
